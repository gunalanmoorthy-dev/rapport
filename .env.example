# Copy to .env.local and fill in. Never commit real secrets — .env*.local is gitignored.

# Neon Postgres pooled connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/db?sslmode=require

# Google Gemini API key (https://aistudio.google.com/apikey).
# Leave blank to run the Echo pipeline in offline mock mode (see AI_MOCK below).
GEMINI_API_KEY=

# Secret used to sign session cookies (any long random string).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# AI mock mode — set "true" to use canned transcripts/extractions instead of
# Gemini (handy for demos/video with no key or cost). Mock is also used
# automatically whenever GEMINI_API_KEY is empty. Unset it (and set a key) for
# real Gemini. Optionally pin one scenario:
#   commit-inflow | commit-outflow | overspend | note | ambiguous
AI_MOCK=true
# AI_MOCK_SCENARIO=commit-inflow
